<script>
  document.querySelectorAll('.compact__toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const wrapper = btn.closest('.compact__expandable');
      if (!wrapper) return;
      const isCollapsed = wrapper.hasAttribute('data-collapsed');
      if (isCollapsed) {
        wrapper.removeAttribute('data-collapsed');
        (btn.querySelector('.compact__toggle-text') as HTMLElement).textContent = 'Show less';
      } else {
        wrapper.setAttribute('data-collapsed', '');
        (btn.querySelector('.compact__toggle-text') as HTMLElement).textContent = 'Show more';
      }
    });
  });
</script>
