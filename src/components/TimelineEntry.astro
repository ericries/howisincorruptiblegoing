---
import type { TimelineEntry } from '../lib/schema';

interface Props {
  entry: TimelineEntry;
  index: number;
}

const { entry, index } = Astro.props;

const dateObj = new Date(entry.date + 'T00:00:00Z');
const month = dateObj.toLocaleString('en-US', { month: 'short', timeZone: 'UTC' }).toUpperCase();
const day = dateObj.getUTCDate();
const year = dateObj.getUTCFullYear();

const accentColors: Record<string, string> = {
  event: 'var(--color-red)',
  endorsement: 'var(--color-blue)',
  review: 'var(--color-red)',
  social: 'var(--color-navy)',
  podcast: 'var(--color-red)',
  media: 'var(--color-blue)',
  milestone: 'var(--color-red)',
};
const accent = accentColors[entry.type] || 'var(--color-navy)';

const sourceDomain = (() => {
  try {
    return new URL(entry.source_url).hostname.replace('www.', '');
  } catch {
    return entry.blockquote_source;
  }
})();

const isFeatured = !!(entry.type_metadata as Record<string, unknown>)?.featured;
const weight = ((entry.type_metadata as Record<string, unknown>)?.weight as number) || 2;
const isCompact = weight === 1;
const isEndorsement = entry.type === 'endorsement' && entry.attribution;
const isReaderReview = isEndorsement && entry.blockquote_source === 'Reader review';
const hasPhoto = isEndorsement && entry.attribution_image;
// Featured non-endorsement entries with attribution get a special "featured review" card
const isFeaturedReview = isFeatured && !isEndorsement && entry.attribution && entry.attribution_image;
const details = (entry.type_metadata as Record<string, unknown>)?.details as string | undefined;

// LinkedIn post detection
const isLinkedInPost = (() => {
  try {
    const host = new URL(entry.source_url).hostname.replace('www.', '');
    return host === 'linkedin.com';
  } catch {
    return false;
  }
})();

// Parse author name from blockquote_source as fallback (e.g. "Denise Hearn on LinkedIn" → "Denise Hearn")
// Skip Eric Ries's own posts (the whole site is about him) and entries without "on LinkedIn" pattern
const linkedInAuthorName = (() => {
  if (!isLinkedInPost) return null;
  const name = entry.attribution || (() => {
    const match = entry.blockquote_source?.match(/^(.+?)\s+on\s+LinkedIn$/);
    return match ? match[1] : null;
  })();
  if (!name || name === 'Eric Ries') return null;
  return name;
})();

// People headshots from type_metadata (for events, podcasts, etc.)
const people = (entry.type_metadata as Record<string, unknown>)?.people as { name: string; image: string }[] | undefined;
const logoUrl = (entry.type_metadata as Record<string, unknown>)?.logo as string | undefined;

// Build links array: primary source + any additional source_urls
const allLinks: { url: string; label: string }[] = [];
allLinks.push({ url: entry.source_url, label: sourceDomain });
if (entry.source_urls) {
  for (const s of entry.source_urls) {
    allLinks.push(s);
  }
}

// YouTube embed URL from video_url
const youtubeEmbedUrl = (() => {
  if (!entry.video_url) return null;
  const match = entry.video_url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]+)/);
  if (match) return `https://www.youtube.com/embed/${match[1]}`;
  return null;
})();

// TikTok embed data from video_url
const tiktokEmbed = (() => {
  if (!entry.video_url) return null;
  const match = entry.video_url.match(/tiktok\.com\/@([^/]+)\/video\/(\d+)/);
  if (match) return { username: match[1], videoId: match[2], url: entry.video_url };
  return null;
})();
---

<div class="timeline-row" id={entry.id} data-date={entry.date} data-type={entry.type} style={`animation-delay: ${index * 0.06}s`}>
  <div class="timeline-date">
    <span class="timeline-date__month">{month}</span>
    <span class="timeline-date__day">{day}</span>
    <span class="timeline-date__year">{year}</span>
  </div>

  <div class="timeline-rail">
    <div class="timeline-rail__dot" style={`background: ${accent};`}></div>
  </div>

  {isReaderReview ? (
    /* ── READER REVIEW: lighter, smaller treatment ── */
    <article class="card card--reader">
      <div class="reader">
        {entry.attribution_image && (
          <img class="reader__photo" src={entry.attribution_image} alt={entry.attribution || ''} loading="lazy" />
        )}
        <div class="reader__content">
          <blockquote class="reader__quote">
            &ldquo;{entry.blockquote}&rdquo;
          </blockquote>
          <div class="reader__who">
            <strong class="reader__name">{entry.attribution}</strong>
            {entry.attribution_title && (
              <span class="reader__role">{entry.attribution_title}</span>
            )}
            <span class="reader__label">Reader review</span>
          </div>
        </div>
      </div>
    </article>
  ) : hasPhoto ? (
    /* ── ENDORSEMENT WITH PHOTO: cinematic card ── */
    <article class="card card--cinematic">
      <div class="cinematic__photo-col">
        <img
          class="cinematic__photo"
          src={entry.attribution_image!}
          alt={entry.attribution!}
          loading="lazy"
        />
        <div class="cinematic__photo-fade"></div>
      </div>
      <div class="cinematic__content">
        <blockquote class="cinematic__quote">
          &ldquo;{entry.blockquote}&rdquo;
        </blockquote>
        <div class="cinematic__who">
          <strong class="cinematic__name">{entry.attribution}</strong>
          {entry.attribution_title && (
            <span class="cinematic__role">{entry.attribution_title}</span>
          )}
        </div>
        <div class="card__links">
          {allLinks.map(link => (
            <a class="card__source" href={link.url} target="_blank" rel="noopener">{link.label}</a>
          ))}
        </div>
      </div>
    </article>
  ) : isEndorsement ? (
    /* ── ENDORSEMENT WITHOUT PHOTO ── */
    <article class="card card--quote-only">
      <div class="quote-only__accent" style={`background: ${accent};`}></div>
      <div class="quote-only__inner">
        <blockquote class="quote-only__quote">
          &ldquo;{entry.blockquote}&rdquo;
        </blockquote>
        <div class="quote-only__who">
          <strong class="quote-only__name">{entry.attribution}</strong>
          {entry.attribution_title && (
            <span class="quote-only__role">{entry.attribution_title}</span>
          )}
        </div>
        <div class="card__links">
          {allLinks.map(link => (
            <a class="card__source" href={link.url} target="_blank" rel="noopener">{link.label}</a>
          ))}
        </div>
      </div>
    </article>
  ) : isFeaturedReview ? (
    /* ── FEATURED REVIEW: title + quote + person photo ── */
    <article class="card card--featured-review">
      <div class="featured-review__inner">
        <h3 class="featured-review__title">{entry.title}</h3>
        <p class="featured-review__summary">{entry.summary}</p>
        <blockquote class="featured-review__quote">
          &ldquo;{entry.blockquote}&rdquo;
        </blockquote>
        <div class="featured-review__who">
          <img class="featured-review__photo" src={entry.attribution_image!} alt={entry.attribution!} loading="lazy" />
          <div class="featured-review__info">
            <strong class="featured-review__name">{entry.attribution}</strong>
            {entry.attribution_title && (
              <span class="featured-review__role">{entry.attribution_title}</span>
            )}
          </div>
        </div>
        <div class="card__links">
          {allLinks.map(link => (
            <a class="card__source" href={link.url} target="_blank" rel="noopener">{link.label}</a>
          ))}
        </div>
      </div>
    </article>
  ) : (
    /* ── STANDARD ENTRY ── */
    <article class={`card card--standard ${entry.image ? 'card--has-hero' : ''} ${isCompact ? 'card--compact' : ''}`}>
      {entry.image ? (
        /* Entry with hero image */
        <Fragment>
          <div class="hero">
            <img class="hero__img" src={entry.image} alt={entry.title} loading="lazy" />
            <div class="hero__overlay"></div>
            <h3 class="hero__title">{entry.title}</h3>
          </div>
          <div class="standard__inner">
            {isLinkedInPost && linkedInAuthorName && (
              <div class="linkedin-byline">
                {entry.attribution_image ? (
                  <img class="linkedin-byline__avatar" src={entry.attribution_image} alt={linkedInAuthorName} loading="lazy" />
                ) : (
                  <div class="linkedin-byline__avatar-placeholder">
                    {linkedInAuthorName.split(' ').map(w => w[0]).join('').slice(0, 2)}
                  </div>
                )}
                <div class="linkedin-byline__info">
                  <strong class="linkedin-byline__name">{linkedInAuthorName}</strong>
                  {entry.attribution_title && (
                    <span class="linkedin-byline__title">{entry.attribution_title}</span>
                  )}
                </div>
                <svg class="linkedin-byline__icon" viewBox="0 0 24 24" width="16" height="16" fill="#0a66c2">
                  <path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/>
                </svg>
              </div>
            )}
            {isCompact ? (
              <Fragment>
                {youtubeEmbedUrl && (
                  <div class="video-embed">
                    <iframe src={youtubeEmbedUrl} title={entry.title} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                  </div>
                )}
                {tiktokEmbed && (
                  <div class="tiktok-embed-wrap">
                    <blockquote class="tiktok-embed" cite={tiktokEmbed.url} data-video-id={tiktokEmbed.videoId} style="max-width:605px;min-width:325px;">
                      <section>
                        <a target="_blank" title={`@${tiktokEmbed.username}`} href={`https://www.tiktok.com/@${tiktokEmbed.username}?refer=embed`}>@{tiktokEmbed.username}</a>
                      </section>
                    </blockquote>
                  </div>
                )}
                <div class="compact__expandable" data-collapsed>
                  <button class="compact__toggle" aria-label="Show more">
                    <span class="compact__toggle-text">Show more</span>
                    <span class="compact__toggle-icon">&#9662;</span>
                  </button>
                  <div class="compact__content">
                    <p class="standard__intro">{entry.summary}</p>
                    <blockquote class="standard__quote">
                      &ldquo;{entry.blockquote}&rdquo;
                      <cite class="standard__cite">{entry.blockquote_source}</cite>
                    </blockquote>
                    {details && <p class="standard__details">{details}</p>}
                  </div>
                </div>
              </Fragment>
            ) : (
              <Fragment>
                <p class="standard__intro">{entry.summary}</p>
                <blockquote class="standard__quote">
                  &ldquo;{entry.blockquote}&rdquo;
                  <cite class="standard__cite">{entry.blockquote_source}</cite>
                </blockquote>
                {youtubeEmbedUrl && (
                  <div class="video-embed">
                    <iframe src={youtubeEmbedUrl} title={entry.title} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                  </div>
                )}
                {tiktokEmbed && (
                  <div class="tiktok-embed-wrap">
                    <blockquote class="tiktok-embed" cite={tiktokEmbed.url} data-video-id={tiktokEmbed.videoId} style="max-width:605px;min-width:325px;">
                      <section>
                        <a target="_blank" title={`@${tiktokEmbed.username}`} href={`https://www.tiktok.com/@${tiktokEmbed.username}?refer=embed`}>@{tiktokEmbed.username}</a>
                      </section>
                    </blockquote>
                  </div>
                )}
                {details && <p class="standard__details">{details}</p>}
              </Fragment>
            )}
            <div class="card__links">
              {allLinks.map(link => (
                <a class="card__source" href={link.url} target="_blank" rel="noopener">{link.label}</a>
              ))}
            </div>
          </div>
        </Fragment>
      ) : (
        /* Entry without image */
        <Fragment>
          <div class="standard__accent" style={`background: ${accent};`}></div>
          <div class="standard__inner">
            {isLinkedInPost && linkedInAuthorName && (
              <div class="linkedin-byline">
                {entry.attribution_image ? (
                  <img class="linkedin-byline__avatar" src={entry.attribution_image} alt={linkedInAuthorName} loading="lazy" />
                ) : (
                  <div class="linkedin-byline__avatar-placeholder">
                    {linkedInAuthorName.split(' ').map(w => w[0]).join('').slice(0, 2)}
                  </div>
                )}
                <div class="linkedin-byline__info">
                  <strong class="linkedin-byline__name">{linkedInAuthorName}</strong>
                  {entry.attribution_title && (
                    <span class="linkedin-byline__title">{entry.attribution_title}</span>
                  )}
                </div>
                <svg class="linkedin-byline__icon" viewBox="0 0 24 24" width="16" height="16" fill="#0a66c2">
                  <path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/>
                </svg>
              </div>
            )}
            {(people || logoUrl) && (
              <div class="entry-visual">
                {people && (
                  <div class="entry-visual__people">
                    {people.map(p => (
                      <div class="entry-visual__person">
                        <img class="entry-visual__avatar" src={p.image} alt={p.name} loading="lazy" />
                        <span class="entry-visual__name">{p.name}</span>
                      </div>
                    ))}
                  </div>
                )}
                {logoUrl && !people && (
                  <img class="entry-visual__logo" src={logoUrl} alt="" loading="lazy" />
                )}
              </div>
            )}
            <h3 class="standard__title">{entry.title}</h3>
            {isCompact ? (
              <Fragment>
                {youtubeEmbedUrl && (
                  <div class="video-embed">
                    <iframe src={youtubeEmbedUrl} title={entry.title} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                  </div>
                )}
                {tiktokEmbed && (
                  <div class="tiktok-embed-wrap">
                    <blockquote class="tiktok-embed" cite={tiktokEmbed.url} data-video-id={tiktokEmbed.videoId} style="max-width:605px;min-width:325px;">
                      <section>
                        <a target="_blank" title={`@${tiktokEmbed.username}`} href={`https://www.tiktok.com/@${tiktokEmbed.username}?refer=embed`}>@{tiktokEmbed.username}</a>
                      </section>
                    </blockquote>
                  </div>
                )}
                <div class="compact__expandable" data-collapsed>
                  <button class="compact__toggle" aria-label="Show more">
                    <span class="compact__toggle-text">Show more</span>
                    <span class="compact__toggle-icon">&#9662;</span>
                  </button>
                  <div class="compact__content">
                    <p class="standard__intro">{entry.summary}</p>
                    <blockquote class="standard__quote">
                      &ldquo;{entry.blockquote}&rdquo;
                      <cite class="standard__cite">{entry.blockquote_source}</cite>
                    </blockquote>
                    {details && <p class="standard__details">{details}</p>}
                  </div>
                </div>
              </Fragment>
            ) : (
              <Fragment>
                <p class="standard__intro">{entry.summary}</p>
                <blockquote class="standard__quote">
                  &ldquo;{entry.blockquote}&rdquo;
                  <cite class="standard__cite">{entry.blockquote_source}</cite>
                </blockquote>
                {youtubeEmbedUrl && (
                  <div class="video-embed">
                    <iframe src={youtubeEmbedUrl} title={entry.title} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                  </div>
                )}
                {tiktokEmbed && (
                  <div class="tiktok-embed-wrap">
                    <blockquote class="tiktok-embed" cite={tiktokEmbed.url} data-video-id={tiktokEmbed.videoId} style="max-width:605px;min-width:325px;">
                      <section>
                        <a target="_blank" title={`@${tiktokEmbed.username}`} href={`https://www.tiktok.com/@${tiktokEmbed.username}?refer=embed`}>@{tiktokEmbed.username}</a>
                      </section>
                    </blockquote>
                  </div>
                )}
                {details && <p class="standard__details">{details}</p>}
              </Fragment>
            )}
            <div class="card__links">
              {allLinks.map(link => (
                <a class="card__source" href={link.url} target="_blank" rel="noopener">{link.label}</a>
              ))}
            </div>
          </div>
        </Fragment>
      )}
    </article>
  )}
</div>

<style>
  /* ═══════════════════════════════
     ROW, DATE, RAIL
     ═══════════════════════════════ */
  .timeline-row {
    display: flex;
    gap: 20px;
    margin-bottom: 2rem;
    animation: cardEnter 0.5s ease both;
  }

  .timeline-date {
    width: var(--date-col-width);
    flex-shrink: 0;
    padding-top: 1.4rem;
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .timeline-date__month {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
  }

  .timeline-date__day {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.1;
  }

  .timeline-date__year {
    font-family: var(--font-body);
    font-size: 0.62rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .timeline-rail {
    width: var(--rail-width);
    background: linear-gradient(to bottom, rgba(26, 30, 58, 0.2), rgba(26, 30, 58, 0.05));
    flex-shrink: 0;
    position: relative;
    border-radius: 2px;
  }

  .timeline-rail__dot {
    width: var(--dot-size);
    height: var(--dot-size);
    border-radius: 50%;
    position: absolute;
    top: 1.8rem;
    left: calc(-1 * (var(--dot-size) - var(--rail-width)) / 2);
    transition: transform 0.25s ease;
  }

  .timeline-row:hover .timeline-rail__dot {
    transform: scale(1.5);
  }

  /* ═══════════════════════════════
     CARD BASE
     ═══════════════════════════════ */
  .card {
    flex: 1;
    border-radius: 16px;
    overflow: hidden;
    transition: box-shadow 0.35s ease, transform 0.35s ease;
    position: relative;
  }

  .card:hover {
    transform: translateY(-3px);
  }

  /* ═══════════════════════════════
     READER REVIEW (lighter treatment)
     ═══════════════════════════════ */
  .card--reader {
    background: var(--color-card);
    box-shadow:
      0 1px 3px var(--color-shadow),
      0 4px 12px var(--color-shadow);
    border: 1px solid var(--color-border);
  }

  .card--reader:hover {
    box-shadow:
      0 2px 6px var(--color-shadow),
      0 8px 24px var(--color-shadow-lg);
  }

  .reader {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    align-items: flex-start;
  }

  .reader__photo {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--color-border);
  }

  .reader__content {
    flex: 1;
    min-width: 0;
  }

  .reader__quote {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    font-style: normal;
    color: var(--color-text);
    line-height: 1.55;
    margin-bottom: 0.75rem;
  }

  .reader__who {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem;
  }

  .reader__name {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-navy);
  }

  .reader__role {
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }

  .reader__label {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: var(--color-gray-bg);
    padding: 2px 8px;
    border-radius: 4px;
  }

  /* ═══════════════════════════════
     CINEMATIC ENDORSEMENT (with photo)
     The photo takes the full left side
     and bleeds/fades into the quote area
     ═══════════════════════════════ */
  .card--cinematic {
    display: flex;
    background: var(--color-navy-deep);
    min-height: 220px;
    box-shadow:
      0 4px 12px rgba(26, 30, 58, 0.15),
      0 12px 40px rgba(26, 30, 58, 0.12);
  }

  .card--cinematic:hover {
    box-shadow:
      0 8px 20px rgba(26, 30, 58, 0.2),
      0 24px 60px rgba(26, 30, 58, 0.18);
  }

  .cinematic__photo-col {
    width: 200px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }

  .cinematic__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: contrast(1.05) brightness(0.95);
  }

  /* Gradient that fades the photo into the dark background */
  .cinematic__photo-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      transparent 40%,
      var(--color-navy-deep) 100%
    );
  }

  /* Top-to-bottom vignette */
  .cinematic__photo-col::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgba(17, 20, 40, 0.4) 100%
    );
  }

  .cinematic__content {
    flex: 1;
    padding: 2rem 2rem 1.75rem 1rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }

  .cinematic__quote {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    font-style: normal;
    color: var(--color-white);
    line-height: 1.55;
    margin-bottom: 1.25rem;
    padding-left: 1.25rem;
    border-left: 3px solid rgba(108, 184, 214, 0.5);
  }

  .cinematic__who {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cinematic__name {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-white);
  }

  .cinematic__role {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 500;
  }

  .card--cinematic .card__source {
    color: rgba(255, 255, 255, 0.3);
  }

