---
import type { TimelineEntry } from '../lib/schema';

interface Props {
  entry: TimelineEntry;
  index: number;
}

const { entry, index } = Astro.props;

const dateObj = new Date(entry.date + 'T00:00:00Z');
const month = dateObj.toLocaleString('en-US', { month: 'short', timeZone: 'UTC' }).toUpperCase();
const day = dateObj.getUTCDate();
const year = dateObj.getUTCFullYear();

// Color accent based on type
const accentColors: Record<string, string> = {
  event: 'var(--color-red)',
  endorsement: 'var(--color-blue)',
  review: 'var(--color-red)',
  social: 'var(--color-navy)',
  podcast: 'var(--color-red)',
  media: 'var(--color-blue)',
  milestone: 'var(--color-red)',
};
const accent = accentColors[entry.type] || 'var(--color-navy)';

// Source domain for link display
const sourceDomain = (() => {
  try {
    return new URL(entry.source_url).hostname.replace('www.', '');
  } catch {
    return entry.blockquote_source;
  }
})();

const isEndorsement = entry.type === 'endorsement' && entry.attribution;
const hasPhoto = isEndorsement && entry.attribution_image;
---

<div class="timeline-row" style={`animation-delay: ${index * 0.06}s`}>
  <div class="timeline-date">
    <span class="timeline-date__month">{month}</span>
    <span class="timeline-date__day">{day}</span>
    <span class="timeline-date__year">{year}</span>
  </div>

  <div class="timeline-rail">
    <div class="timeline-rail__dot" style={`background: ${accent};`}></div>
  </div>

  <article class={`timeline-card ${isEndorsement ? 'timeline-card--endorsement' : ''} ${hasPhoto ? 'timeline-card--has-photo' : ''}`}>
    {/* Accent stripe */}
    <div class="timeline-card__accent" style={`background: ${accent};`}></div>

    {isEndorsement ? (
      /* ── ENDORSEMENT LAYOUT ── */
      <div class="endorsement">
        {hasPhoto && (
          <div class="endorsement__photo-wrap">
            <img
              class="endorsement__photo"
              src={entry.attribution_image!}
              alt={entry.attribution!}
              loading="lazy"
            />
          </div>
        )}
        <div class="endorsement__content">
          <blockquote class="endorsement__quote">
            {entry.blockquote}
          </blockquote>
          <div class="endorsement__attribution">
            <strong class="endorsement__name">{entry.attribution}</strong>
            {entry.attribution_title && (
              <span class="endorsement__role">{entry.attribution_title}</span>
            )}
          </div>
          <a class="timeline-card__source" href={entry.source_url} target="_blank" rel="noopener">
            {sourceDomain}
          </a>
        </div>
      </div>
    ) : (
      /* ── STANDARD LAYOUT ── */
      <div class="standard">
        {entry.image && (
          <img class="standard__image" src={entry.image} alt={entry.title} loading="lazy" />
        )}
        <h3 class="standard__title">{entry.title}</h3>
        <p class="standard__summary">{entry.summary}</p>
        <blockquote class="standard__quote">
          {entry.blockquote}
          <cite class="standard__cite">{entry.blockquote_source}</cite>
        </blockquote>
        <a class="timeline-card__source" href={entry.source_url} target="_blank" rel="noopener">
          {sourceDomain}
        </a>
      </div>
    )}
  </article>
</div>

<style>
  /* ── ROW ── */
  .timeline-row {
    display: flex;
    gap: 20px;
    margin-bottom: 2rem;
    animation: cardEnter 0.5s ease both;
  }

  /* ── DATE ── */
  .timeline-date {
    width: var(--date-col-width);
    flex-shrink: 0;
    padding-top: 1.4rem;
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .timeline-date__month {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
  }

  .timeline-date__day {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.1;
  }

  .timeline-date__year {
    font-family: var(--font-body);
    font-size: 0.62rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* ── RAIL ── */
  .timeline-rail {
    width: var(--rail-width);
    background: linear-gradient(to bottom, rgba(26, 30, 58, 0.2), rgba(26, 30, 58, 0.05));
    flex-shrink: 0;
    position: relative;
    border-radius: 2px;
  }

  .timeline-rail__dot {
    width: var(--dot-size);
    height: var(--dot-size);
    border-radius: 50%;
    position: absolute;
    top: 1.8rem;
    left: calc(-1 * (var(--dot-size) - var(--rail-width)) / 2);
    transition: transform 0.25s ease;
  }

  .timeline-row:hover .timeline-rail__dot {
    transform: scale(1.5);
  }

  /* ── CARD BASE ── */
  .timeline-card {
    flex: 1;
    background: var(--color-card);
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
      0 2px 4px var(--color-shadow),
      0 8px 24px var(--color-shadow);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    position: relative;
  }

  .timeline-card:hover {
    box-shadow:
      0 4px 8px var(--color-shadow),
      0 16px 48px var(--color-shadow-lg);
    transform: translateY(-3px);
  }

  .timeline-card__accent {
    height: 4px;
  }

  /* ── ENDORSEMENT ── */
  .endorsement {
    display: flex;
    align-items: stretch;
  }

  .endorsement__photo-wrap {
    width: 140px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    background: linear-gradient(145deg, var(--color-navy), #2a3060);
  }

  .endorsement__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    min-height: 160px;
  }

  .endorsement__content {
    flex: 1;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .endorsement__quote {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.55;
    margin-bottom: 1rem;
    position: relative;
  }

  .endorsement__quote::before {
    content: '\201C';
    font-family: var(--font-display);
    font-size: 4rem;
    color: var(--color-blue);
    opacity: 0.15;
    position: absolute;
    top: -20px;
    left: -8px;
    line-height: 1;
    font-style: normal;
  }

  .endorsement__attribution {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .endorsement__name {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
  }

  .endorsement__role {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* ── STANDARD ── */
  .standard {
    padding: 1.75rem;
  }

  .standard__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.25;
    margin-bottom: 0.75rem;
  }

  .standard__summary {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .standard__quote {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-text);
    font-style: italic;
    line-height: 1.6;
    margin: 1rem 0;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, rgba(26, 30, 58, 0.03), rgba(108, 184, 214, 0.04));
    border-left: 4px solid var(--color-blue);
    border-radius: 0 12px 12px 0;
    position: relative;
  }

  .standard__quote::before {
    content: '\201C';
    font-family: var(--font-display);
    font-size: 4rem;
    color: var(--color-blue);
    opacity: 0.12;
    position: absolute;
    top: -16px;
    left: 8px;
    line-height: 1;
    font-style: normal;
  }

  .standard__cite {
    display: block;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-text-muted);
    font-style: normal;
    margin-top: 0.6rem;
  }

  .standard__cite::before {
    content: '— ';
  }

  .standard__image {
    width: 100%;
    border-radius: 8px;
    margin-bottom: 1.25rem;
  }

  /* ── SOURCE LINK ── */
  .timeline-card__source {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
    transition: color 0.2s ease;
  }

  .timeline-card__source:hover {
    color: var(--color-blue);
    text-decoration: none;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
    .endorsement {
      flex-direction: column;
    }

    .endorsement__photo-wrap {
      width: 100%;
      height: 180px;
    }

    .endorsement__content {
      padding: 1.25rem;
    }

    .standard {
      padding: 1.25rem;
    }

    .standard__title {
      font-size: 1.25rem;
    }

    .endorsement__quote,
    .standard__quote {
      font-size: 1rem;
    }
  }
</style>
