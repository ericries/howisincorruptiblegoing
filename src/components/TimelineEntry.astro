---
import type { TimelineEntry } from '../lib/schema';

interface Props {
  entry: TimelineEntry;
  index: number;
}

const { entry, index } = Astro.props;

const dateObj = new Date(entry.date + 'T00:00:00Z');
const month = dateObj.toLocaleString('en-US', { month: 'long', timeZone: 'UTC' });
const day = dateObj.getUTCDate();
const year = dateObj.getUTCFullYear();

const dateStr = `${month} ${day}, ${year}`;

// Color accent based on type (subtle, no labels)
const accentColors: Record<string, string> = {
  event: 'var(--color-red)',
  endorsement: 'var(--color-blue)',
  review: 'var(--color-red)',
  social: 'var(--color-navy)',
  podcast: 'var(--color-red)',
  media: 'var(--color-blue)',
  milestone: 'var(--color-red)',
};
const accent = accentColors[entry.type] || 'var(--color-navy)';

// Extract domain from source_url for display
const sourceDomain = (() => {
  try {
    const url = new URL(entry.source_url);
    return url.hostname.replace('www.', '');
  } catch {
    return entry.blockquote_source;
  }
})();
---

<div class="timeline-row" style={`animation-delay: ${index * 0.06}s`}>
  <div class="timeline-date">
    <span class="timeline-date__text">{dateStr}</span>
  </div>

  <div class="timeline-rail">
    <div class="timeline-rail__dot" style={`background: ${accent}; box-shadow: 0 0 10px ${accent}33;`}></div>
  </div>

  <article class="timeline-card" style={`border-top-color: ${accent};`}>
    {/* Attribution photo — large, prominent */}
    {entry.type === 'endorsement' && entry.attribution ? (
      <div class="timeline-card__inner">
        <div class="timeline-card__portrait">
          <div class="timeline-card__avatar-large">
            {entry.attribution_image ? (
              <img src={entry.attribution_image} alt={entry.attribution} loading="lazy" />
            ) : (
              <span class="timeline-card__initials">{entry.attribution.split(' ').map(n => n[0]).join('')}</span>
            )}
          </div>
        </div>
        <div class="timeline-card__body">
          <h3 class="timeline-card__title">{entry.attribution}</h3>
          {entry.attribution_title && (
            <div class="timeline-card__role">{entry.attribution_title}</div>
          )}
          <blockquote class="timeline-card__quote">
            <span class="timeline-card__quote-mark" aria-hidden="true">&ldquo;</span>
            {entry.blockquote}
          </blockquote>
          <p class="timeline-card__summary">{entry.summary}</p>
          <a class="timeline-card__source" href={entry.source_url} target="_blank" rel="noopener">
            {sourceDomain}
          </a>
        </div>
      </div>
    ) : (
      <div class="timeline-card__body">
        {entry.image && (
          <img class="timeline-card__image" src={entry.image} alt={entry.title} loading="lazy" />
        )}
        <h3 class="timeline-card__title">{entry.title}</h3>
        <p class="timeline-card__summary">{entry.summary}</p>
        <blockquote class="timeline-card__quote">
          <span class="timeline-card__quote-mark" aria-hidden="true">&ldquo;</span>
          {entry.blockquote}
          <cite class="timeline-card__cite">{entry.blockquote_source}</cite>
        </blockquote>
        <a class="timeline-card__source" href={entry.source_url} target="_blank" rel="noopener">
          {sourceDomain}
        </a>
      </div>
    )}
  </article>
</div>

<style>
  .timeline-row {
    display: flex;
    gap: 20px;
    margin-bottom: 1.75rem;
    animation: cardEnter 0.45s ease both;
  }

  .timeline-date {
    width: var(--date-col-width);
    flex-shrink: 0;
    padding-top: 1.2rem;
    text-align: right;
  }

  .timeline-date__text {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
    line-height: 1.3;
    display: block;
  }

  .timeline-rail {
    width: var(--rail-width);
    background: linear-gradient(to bottom, rgba(26, 30, 58, 0.25), rgba(26, 30, 58, 0.08));
    flex-shrink: 0;
    position: relative;
  }

  .timeline-rail__dot {
    width: var(--dot-size);
    height: var(--dot-size);
    border-radius: 50%;
    position: absolute;
    top: 1.35rem;
    left: calc(-1 * (var(--dot-size) - var(--rail-width)) / 2);
    transition: transform 0.2s ease;
  }

  .timeline-row:hover .timeline-rail__dot {
    transform: scale(1.4);
  }

  .timeline-card {
    flex: 1;
    background: var(--color-card);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow:
      0 1px 2px var(--color-shadow),
      0 4px 20px var(--color-shadow);
    border: 1px solid var(--color-border);
    border-top: 3px solid transparent;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .timeline-card:hover {
    box-shadow:
      0 2px 4px var(--color-shadow),
      0 12px 40px var(--color-shadow-lg);
    transform: translateY(-2px);
  }

  /* Endorsement layout: large photo + text side by side */
  .timeline-card__inner {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .timeline-card__portrait {
    flex-shrink: 0;
  }

  .timeline-card__avatar-large {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--color-navy), #2a3060);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(26, 30, 58, 0.2);
  }

  .timeline-card__avatar-large img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .timeline-card__initials {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-white);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .timeline-card__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .timeline-card__role {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .timeline-card__summary {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .timeline-card__quote {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-text);
    font-style: italic;
    line-height: 1.6;
    margin: 0.75rem 0;
    padding: 1rem 1.25rem;
    background: linear-gradient(135deg, rgba(108, 184, 214, 0.05), rgba(26, 30, 58, 0.02));
    border-left: 3px solid var(--color-blue);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    position: relative;
  }

  .timeline-card__quote-mark {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--color-blue);
    opacity: 0.15;
    position: absolute;
    top: -2px;
    left: 10px;
    line-height: 1;
    font-style: normal;
  }

  .timeline-card__cite {
    display: block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-muted);
    font-style: normal;
    margin-top: 0.6rem;
  }

  .timeline-card__cite::before {
    content: '— ';
  }

  .timeline-card__image {
    width: 100%;
    border-radius: var(--radius-sm);
    margin-bottom: 1rem;
  }

  .timeline-card__source {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    padding: 0;
    transition: color 0.2s ease;
    border-bottom: 1px solid transparent;
  }

  .timeline-card__source:hover {
    color: var(--color-blue);
    border-bottom-color: var(--color-blue);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .timeline-card__inner {
      flex-direction: column;
      gap: 1rem;
    }

    .timeline-card__avatar-large {
      width: 64px;
      height: 64px;
    }

    .timeline-card {
      padding: 1.1rem;
    }
  }
</style>
