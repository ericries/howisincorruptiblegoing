---
import type { TimelineEntry } from '../lib/schema';

interface Props {
  entry: TimelineEntry;
  index: number;
}

const { entry, index } = Astro.props;

const dateObj = new Date(entry.date + 'T00:00:00Z');
const month = dateObj.toLocaleString('en-US', { month: 'short', timeZone: 'UTC' }).toUpperCase();
const day = dateObj.getUTCDate();
const year = dateObj.getUTCFullYear();

const accentColors: Record<string, string> = {
  event: 'var(--color-red)',
  endorsement: 'var(--color-blue)',
  review: 'var(--color-red)',
  social: 'var(--color-navy)',
  podcast: 'var(--color-red)',
  media: 'var(--color-blue)',
  milestone: 'var(--color-red)',
};
const accent = accentColors[entry.type] || 'var(--color-navy)';

const sourceDomain = (() => {
  try {
    return new URL(entry.source_url).hostname.replace('www.', '');
  } catch {
    return entry.blockquote_source;
  }
})();

const isEndorsement = entry.type === 'endorsement' && entry.attribution;
const hasPhoto = isEndorsement && entry.attribution_image;
const details = (entry.type_metadata as Record<string, unknown>)?.details as string | undefined;

// Build links array: primary source + any additional source_urls
const allLinks: { url: string; label: string }[] = [];
allLinks.push({ url: entry.source_url, label: sourceDomain });
if (entry.source_urls) {
  for (const s of entry.source_urls) {
    allLinks.push(s);
  }
}

// YouTube embed URL from video_url
const youtubeEmbedUrl = (() => {
  if (!entry.video_url) return null;
  const match = entry.video_url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]+)/);
  if (match) return `https://www.youtube.com/embed/${match[1]}`;
  return null;
})();
---

<div class="timeline-row" style={`animation-delay: ${index * 0.06}s`}>
  <div class="timeline-date">
    <span class="timeline-date__month">{month}</span>
    <span class="timeline-date__day">{day}</span>
    <span class="timeline-date__year">{year}</span>
  </div>

  <div class="timeline-rail">
    <div class="timeline-rail__dot" style={`background: ${accent};`}></div>
  </div>

  {hasPhoto ? (
    /* ── ENDORSEMENT WITH PHOTO: cinematic card ── */
    <article class="card card--cinematic">
      <div class="cinematic__photo-col">
        <img
          class="cinematic__photo"
          src={entry.attribution_image!}
          alt={entry.attribution!}
          loading="lazy"
        />
        <div class="cinematic__photo-fade"></div>
      </div>
      <div class="cinematic__content">
        <blockquote class="cinematic__quote">
          {entry.blockquote}
        </blockquote>
        <div class="cinematic__who">
          <strong class="cinematic__name">{entry.attribution}</strong>
          {entry.attribution_title && (
            <span class="cinematic__role">{entry.attribution_title}</span>
          )}
        </div>
        <div class="card__links">
          {allLinks.map(link => (
            <a class="card__source" href={link.url} target="_blank" rel="noopener">{link.label}</a>
          ))}
        </div>
      </div>
    </article>
  ) : isEndorsement ? (
    /* ── ENDORSEMENT WITHOUT PHOTO ── */
    <article class="card card--quote-only">
      <div class="quote-only__accent" style={`background: ${accent};`}></div>
      <div class="quote-only__inner">
        <blockquote class="quote-only__quote">
          {entry.blockquote}
        </blockquote>
        <div class="quote-only__who">
          <strong class="quote-only__name">{entry.attribution}</strong>
          {entry.attribution_title && (
            <span class="quote-only__role">{entry.attribution_title}</span>
          )}
        </div>
        <div class="card__links">
          {allLinks.map(link => (
            <a class="card__source" href={link.url} target="_blank" rel="noopener">{link.label}</a>
          ))}
        </div>
      </div>
    </article>
  ) : (
    /* ── STANDARD ENTRY ── */
    <article class={`card card--standard ${entry.image ? 'card--has-hero' : ''}`}>
      {entry.image ? (
        /* Entry with hero image */
        <Fragment>
          <div class="hero">
            <img class="hero__img" src={entry.image} alt={entry.title} loading="lazy" />
            <div class="hero__overlay"></div>
            <h3 class="hero__title">{entry.title}</h3>
          </div>
          <div class="standard__inner">
            <p class="standard__intro">{entry.summary}</p>
            <blockquote class="standard__quote">
              {entry.blockquote}
              <cite class="standard__cite">{entry.blockquote_source}</cite>
            </blockquote>
            {youtubeEmbedUrl && (
              <div class="video-embed">
                <iframe src={youtubeEmbedUrl} title={entry.title} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
              </div>
            )}
            {details && <p class="standard__details">{details}</p>}
            <div class="card__links">
              {allLinks.map(link => (
                <a class="card__source" href={link.url} target="_blank" rel="noopener">{link.label}</a>
              ))}
            </div>
          </div>
        </Fragment>
      ) : (
        /* Entry without image */
        <Fragment>
          <div class="standard__accent" style={`background: ${accent};`}></div>
          <div class="standard__inner">
            <h3 class="standard__title">{entry.title}</h3>
            <p class="standard__intro">{entry.summary}</p>
            <blockquote class="standard__quote">
              {entry.blockquote}
              <cite class="standard__cite">{entry.blockquote_source}</cite>
            </blockquote>
            {youtubeEmbedUrl && (
              <div class="video-embed">
                <iframe src={youtubeEmbedUrl} title={entry.title} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
              </div>
            )}
            {details && <p class="standard__details">{details}</p>}
            <div class="card__links">
              {allLinks.map(link => (
                <a class="card__source" href={link.url} target="_blank" rel="noopener">{link.label}</a>
              ))}
            </div>
          </div>
        </Fragment>
      )}
    </article>
  )}
</div>

<style>
  /* ═══════════════════════════════
     ROW, DATE, RAIL
     ═══════════════════════════════ */
  .timeline-row {
    display: flex;
    gap: 20px;
    margin-bottom: 2rem;
    animation: cardEnter 0.5s ease both;
  }

  .timeline-date {
    width: var(--date-col-width);
    flex-shrink: 0;
    padding-top: 1.4rem;
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .timeline-date__month {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
  }

  .timeline-date__day {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.1;
  }

  .timeline-date__year {
    font-family: var(--font-body);
    font-size: 0.62rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .timeline-rail {
    width: var(--rail-width);
    background: linear-gradient(to bottom, rgba(26, 30, 58, 0.2), rgba(26, 30, 58, 0.05));
    flex-shrink: 0;
    position: relative;
    border-radius: 2px;
  }

  .timeline-rail__dot {
    width: var(--dot-size);
    height: var(--dot-size);
    border-radius: 50%;
    position: absolute;
    top: 1.8rem;
    left: calc(-1 * (var(--dot-size) - var(--rail-width)) / 2);
    transition: transform 0.25s ease;
  }

  .timeline-row:hover .timeline-rail__dot {
    transform: scale(1.5);
  }

  /* ═══════════════════════════════
     CARD BASE
     ═══════════════════════════════ */
  .card {
    flex: 1;
    border-radius: 16px;
    overflow: hidden;
    transition: box-shadow 0.35s ease, transform 0.35s ease;
    position: relative;
  }

  .card:hover {
    transform: translateY(-3px);
  }

  /* ═══════════════════════════════
     CINEMATIC ENDORSEMENT (with photo)
     The photo takes the full left side
     and bleeds/fades into the quote area
     ═══════════════════════════════ */
  .card--cinematic {
    display: flex;
    background: var(--color-navy-deep);
    min-height: 220px;
    box-shadow:
      0 4px 12px rgba(26, 30, 58, 0.15),
      0 12px 40px rgba(26, 30, 58, 0.12);
  }

  .card--cinematic:hover {
    box-shadow:
      0 8px 20px rgba(26, 30, 58, 0.2),
      0 24px 60px rgba(26, 30, 58, 0.18);
  }

  .cinematic__photo-col {
    width: 200px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }

  .cinematic__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: contrast(1.05) brightness(0.95);
  }

  /* Gradient that fades the photo into the dark background */
  .cinematic__photo-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      transparent 40%,
      var(--color-navy-deep) 100%
    );
  }

  /* Top-to-bottom vignette */
  .cinematic__photo-col::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgba(17, 20, 40, 0.4) 100%
    );
  }

  .cinematic__content {
    flex: 1;
    padding: 2rem 2rem 1.75rem 1rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }

  .cinematic__quote {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-style: normal;
    color: rgba(255, 255, 255, 0.95);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    position: relative;
    padding-left: 1.25rem;
    border-left: 3px solid rgba(108, 184, 214, 0.4);
  }

  .cinematic__quote::before {
    content: '\201C';
    font-family: var(--font-display);
    font-size: 3.5rem;
    color: var(--color-blue);
    opacity: 0.35;
    position: absolute;
    top: -10px;
    left: -4px;
    line-height: 1;
  }

  .cinematic__quote::after {
    content: '\201D';
  }

  .cinematic__who {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cinematic__name {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-white);
  }

  .cinematic__role {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 500;
  }

  .card--cinematic .card__source {
    color: rgba(255, 255, 255, 0.3);
  }

  .card--cinematic .card__source:hover {
    color: var(--color-blue);
  }

  /* ═══════════════════════════════
     QUOTE-ONLY ENDORSEMENT (no photo)
     ═══════════════════════════════ */
  .card--quote-only {
    background: var(--color-card);
    box-shadow:
      0 2px 4px var(--color-shadow),
      0 8px 24px var(--color-shadow);
  }

  .card--quote-only:hover {
    box-shadow:
      0 4px 8px var(--color-shadow),
      0 16px 48px var(--color-shadow-lg);
  }

  .quote-only__accent {
    height: 4px;
  }

  .quote-only__inner {
    padding: 1.75rem;
  }

  .quote-only__quote {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-style: normal;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 1rem;
    position: relative;
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-blue);
  }

  .quote-only__quote::before {
    content: '\201C';
    font-family: var(--font-display);
    font-size: 3.5rem;
    color: var(--color-blue);
    opacity: 0.2;
    position: absolute;
    top: -10px;
    left: -4px;
    line-height: 1;
  }

  .quote-only__quote::after {
    content: '\201D';
  }

  .quote-only__who {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .quote-only__name {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
  }

  .quote-only__role {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* ═══════════════════════════════
     STANDARD ENTRY
     ═══════════════════════════════ */
  .card--standard {
    background: var(--color-card);
    box-shadow:
      0 2px 4px var(--color-shadow),
      0 8px 24px var(--color-shadow);
  }

  .card--standard:hover {
    box-shadow:
      0 4px 8px var(--color-shadow),
      0 16px 48px var(--color-shadow-lg);
  }

  .standard__accent {
    height: 4px;
  }

  .standard__inner {
    padding: 1.75rem;
  }

  .standard__title {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.25;
    margin-bottom: 0.75rem;
  }

  .standard__intro {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .standard__details {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .standard__quote {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-text);
    font-style: normal;
    line-height: 1.65;
    margin: 0.75rem 0;
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-blue);
    position: relative;
  }

  .standard__quote::before {
    content: '\201C';
    font-family: var(--font-display);
    font-size: 3.5rem;
    color: var(--color-blue);
    opacity: 0.2;
    position: absolute;
    top: -10px;
    left: -4px;
    line-height: 1;
  }

  .standard__quote::after {
    content: '\201D';
  }

  .standard__cite {
    display: block;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-text-muted);
    font-style: normal;
    margin-top: 0.6rem;
  }

  .standard__cite::before {
    content: '— ';
  }

  /* ── HERO IMAGE ── */
  .hero {
    position: relative;
    height: 240px;
    overflow: hidden;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 30%,
      rgba(26, 30, 58, 0.7) 80%,
      rgba(26, 30, 58, 0.95) 100%
    );
  }

  .hero__title {
    position: absolute;
    bottom: 1.25rem;
    left: 1.75rem;
    right: 1.75rem;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.25;
    z-index: 1;
    text-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  /* ═══════════════════════════════
     SOURCE LINK (shared)
     ═══════════════════════════════ */
  .card__source {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
    transition: color 0.2s ease;
  }

  .card__source:hover {
    color: var(--color-blue);
    text-decoration: none;
  }

  .card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }

  .card__links .card__source::before {
    content: '↗ ';
    font-size: 0.65rem;
  }

  /* ── VIDEO EMBED ── */
  .video-embed {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    margin: 1rem 0;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }

  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ═══════════════════════════════
     RESPONSIVE
     ═══════════════════════════════ */
  @media (max-width: 640px) {
    .card--cinematic {
      flex-direction: column;
      min-height: auto;
    }

    .cinematic__photo-col {
      width: 100%;
      height: 200px;
    }

    .cinematic__photo-fade {
      background: linear-gradient(
        to bottom,
        transparent 40%,
        var(--color-navy-deep) 100%
      );
    }

    .cinematic__content {
      padding: 1.5rem;
    }

    .cinematic__quote {
      font-size: 1.05rem;
    }

    .standard__inner,
    .quote-only__inner {
      padding: 1.25rem;
    }

    .standard__title {
      font-size: 1.25rem;
    }
  }
</style>
