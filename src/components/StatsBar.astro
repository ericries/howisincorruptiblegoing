---
interface Props {
  totalEntries: number;
  totalEndorsements: number;
}

const { totalEntries, totalEndorsements } = Astro.props;

const LAUNCH_DATE = new Date('2026-05-26T00:00:00Z');
const now = new Date();
const daysToLaunch = Math.max(
  0,
  Math.ceil((LAUNCH_DATE.getTime() - now.getTime()) / (1000 * 60 * 60 * 24))
);
---

<div class="stats">
  <div class="stats__inner">
    <div class="stats__item">
      <span class="stats__number stats__number--red">{daysToLaunch}</span>
      <span class="stats__label">days to launch</span>
    </div>
    <div class="stats__divider"></div>
    <div class="stats__item">
      <span class="stats__number stats__number--blue">{totalEntries}</span>
      <span class="stats__label">entries</span>
    </div>
    <div class="stats__divider"></div>
    <div class="stats__item">
      <span class="stats__number stats__number--white">{totalEndorsements}</span>
      <span class="stats__label">endorsements</span>
    </div>
  </div>
</div>

<style>
  .stats {
    background: var(--color-navy);
    padding: 1.1rem 1rem;
    border-bottom: 1px solid rgba(108, 184, 214, 0.08);
  }

  .stats__inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .stats__number {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1;
  }

  .stats__number--red { color: var(--color-red); }
  .stats__number--blue { color: var(--color-blue); }
  .stats__number--white { color: var(--color-white); }

  .stats__label {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .stats__divider {
    width: 1px;
    height: 28px;
    background: rgba(108, 184, 214, 0.12);
  }

  @media (max-width: 640px) {
    .stats__inner {
      gap: 1.25rem;
    }

    .stats__number {
      font-size: 1.3rem;
    }
  }
</style>
