---
import type { TimelineEntry } from '../lib/schema';

interface Props {
  entries: TimelineEntry[];
}

const { entries } = Astro.props;

interface Highlight {
  id: string;
  teaser: string;
  image: string | null;
  name: string | null;
}

const highlights: Highlight[] = entries
  .filter(e => (e.type_metadata as any)?.highlight)
  .map(e => ({
    id: e.id,
    teaser: (e.type_metadata as any).highlight as string,
    image: e.attribution_image || e.image || null,
    name: e.attribution || null,
  }));

if (highlights.length === 0) return;
---

<div class="highlights" id="highlights">
  <button class="highlights__arrow highlights__arrow--left" id="hl-prev" aria-label="Previous">&lsaquo;</button>
  <div class="highlights__track" id="highlights-track">
    {highlights.map(h => (
      <button class="highlight-card" data-scroll-to={h.id}>
        {h.image && (
          <img class="highlight-card__img" src={h.image} alt={h.name || ''} loading="lazy" />
        )}
        <span class="highlight-card__teaser">{h.teaser}</span>
      </button>
    ))}
  </div>
  <button class="highlights__arrow highlights__arrow--right" id="hl-next" aria-label="Next">&rsaquo;</button>
</div>

<style>
  .highlights {
    background: var(--color-navy);
    padding: 0.85rem 0;
    overflow: hidden;
    position: relative;
  }

  /* Fade edges */
  .highlights::before,
  .highlights::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 48px;
    z-index: 2;
    pointer-events: none;
  }

  .highlights::before {
    left: 0;
    background: linear-gradient(to right, var(--color-navy), transparent);
  }

  .highlights::after {
    right: 0;
    background: linear-gradient(to left, var(--color-navy), transparent);
  }

  /* Arrow buttons */
  .highlights__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .highlights__arrow:hover {
    background: rgba(255, 255, 255, 0.15);
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .highlights__arrow--left { left: 6px; }
  .highlights__arrow--right { right: 6px; }

  /* Track */
  .highlights__track {
    display: flex;
    gap: 0.75rem;
    padding: 0 2.5rem;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .highlights__track::-webkit-scrollbar {
    display: none;
  }

  /* Cards */
  .highlight-card {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 1rem 0.5rem 0.5rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
    font-family: var(--font-body);
  }

  .highlight-card:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(108, 184, 214, 0.3);
  }

  .highlight-card__img {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .highlight-card__teaser {
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
    white-space: nowrap;
  }
</style>

<script>
  const track = document.getElementById('highlights-track');
  const cards = track ? Array.from(track.querySelectorAll('.highlight-card')) : [];
  let currentCard = 0;
  let autoTimer: ReturnType<typeof setInterval> | null = null;

  function scrollToCard(index: number) {
    if (!track || cards.length === 0) return;
    currentCard = ((index % cards.length) + cards.length) % cards.length;
    const card = cards[currentCard] as HTMLElement;
    const trackRect = track.getBoundingClientRect();
    const cardRect = card.getBoundingClientRect();
    const offset = cardRect.left - trackRect.left - 40; // 40px padding
    track.scrollBy({ left: offset, behavior: 'smooth' });
  }

  function nextCard() { scrollToCard(currentCard + 1); }
  function prevCard() { scrollToCard(currentCard - 1); }

  function resetAuto() {
    if (autoTimer) clearInterval(autoTimer);
    autoTimer = setInterval(nextCard, 6000);
  }

  // Arrow buttons
  document.getElementById('hl-prev')?.addEventListener('click', () => {
    prevCard();
    resetAuto();
  });

  document.getElementById('hl-next')?.addEventListener('click', () => {
    nextCard();
    resetAuto();
  });

  // Click card to scroll to entry
  cards.forEach(card => {
    card.addEventListener('click', () => {
      const id = card.getAttribute('data-scroll-to');
      if (!id) return;
      const target = document.getElementById(id);
      if (target) {
        target.classList.remove('hidden');
        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        const article = target.querySelector('article');
        if (article) {
          article.style.transition = 'box-shadow 0.3s ease';
          article.style.boxShadow = '0 0 0 3px rgba(108, 184, 214, 0.5)';
          setTimeout(() => { article.style.boxShadow = ''; }, 2000);
        }
      }
    });
  });

  // Start auto-advance (slow — every 6 seconds, one card at a time)
  if (cards.length > 3) {
    resetAuto();
  }
</script>
