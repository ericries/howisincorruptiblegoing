---
---

<header class="header">
  <div class="header__shimmer"></div>
  <div class="header__content">
    <div class="header__pre">How is</div>
    <div class="header__title-wrap">
      <div class="header__echo header__echo--1" aria-hidden="true">INCORRUPTIBLE</div>
      <div class="header__echo header__echo--2" aria-hidden="true">INCORRUPTIBLE</div>
      <h1 class="header__title">INCORRUPTIBLE</h1>
    </div>
    <div class="header__post">going?</div>
    <p class="header__subtitle">
      The new book by <span class="header__author">Eric Ries</span> · May 26, 2026
    </p>
  </div>
</header>

<style>
  .header {
    background: var(--color-navy-dark);
    padding: 5rem 1.5rem 4.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .header__shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      110deg,
      transparent 20%,
      rgba(108, 184, 214, 0.07) 35%,
      rgba(180, 140, 220, 0.05) 45%,
      rgba(232, 64, 64, 0.04) 55%,
      rgba(108, 184, 214, 0.06) 65%,
      transparent 80%
    );
    background-size: 200% 100%;
    animation: shimmer 7s ease-in-out infinite;
    pointer-events: none;
  }

  .header__content {
    position: relative;
    z-index: 1;
  }

  .header__pre,
  .header__post {
    font-family: var(--font-body);
    font-size: 1rem;
    letter-spacing: 0.45em;
    color: var(--color-blue);
    text-transform: uppercase;
    font-weight: 500;
  }

  .header__pre { margin-bottom: 1rem; }
  .header__post { margin-top: 1rem; }

  .header__title-wrap {
    position: relative;
    display: inline-block;
  }

  .header__echo {
    font-family: var(--font-title);
    font-size: 4.5rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    user-select: none;
    color: transparent;
  }

  .header__echo--1 {
    -webkit-text-stroke: 1px rgba(108, 184, 214, 0.1);
    top: 8px;
  }

  .header__echo--2 {
    -webkit-text-stroke: 1px rgba(232, 64, 64, 0.05);
    top: 16px;
  }

  .header__title {
    font-family: var(--font-title);
    font-size: 4.5rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    color: var(--color-white);
    position: relative;
    text-shadow: 0 0 80px rgba(108, 184, 214, 0.12);
  }

  .header__subtitle {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-top: 1.75rem;
    letter-spacing: 0.03em;
  }

  .header__author {
    color: var(--color-red);
    font-weight: 700;
  }

  /* Clean bottom edge — iridescent gradient border only */
  .header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-blue),
      rgba(180, 140, 220, 0.6),
      var(--color-red),
      rgba(180, 140, 220, 0.6),
      var(--color-blue),
      transparent
    );
  }

  @media (max-width: 640px) {
    .header {
      padding: 3rem 1rem 2.5rem;
    }

    .header__title,
    .header__echo {
      font-size: 2.2rem;
      letter-spacing: 0.12em;
    }

    .header__echo--1 { top: 5px; }
    .header__echo--2 { top: 10px; }

    .header__pre,
    .header__post {
      font-size: 0.8rem;
    }
  }
</style>
