---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import StatsBar from '../components/StatsBar.astro';
import TimelineEntry from '../components/TimelineEntry.astro';
import Highlights from '../components/Highlights.astro';
import { loadEntries } from '../lib/entries';
import * as path from 'path';

const entriesDir = path.join(process.cwd(), 'content', 'entries');
const entries = loadEntries(entriesDir);
const totalEndorsements = entries.filter((e) => e.type === 'endorsement').length;

const today = new Date().toISOString().slice(0, 10);

// Split entries into future (upcoming) and past
const futureEntries = entries.filter(e => e.date > today);
const pastEntries = entries.filter(e => e.date <= today);

// Sidebar: What's New (curated via type_metadata.featured)
const featuredEntries = entries
  .filter(e => (e.type_metadata as Record<string, unknown>)?.featured)
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 4);

// Sidebar: Upcoming — split into book tour (has city) vs virtual
const allUpcoming = futureEntries
  .filter(e => e.type === 'event' || e.type === 'podcast')
  .sort((a, b) => a.date.localeCompare(b.date))
  .map(e => {
    const meta = e.type_metadata as Record<string, unknown>;
    return { ...e, city: (meta?.city as string) || null };
  });
const bookTourStops = allUpcoming.filter(e => e.city);
const virtualEvents = allUpcoming.filter(e => !e.city);

// Sidebar: Highlights (curated pull quotes via type_metadata.sidebar_quote)
const sidebarQuotes = entries
  .filter(e => (e.type_metadata as Record<string, unknown>)?.sidebar_quote)
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 3)
  .map(e => ({
    id: e.id,
    quote: (e.type_metadata as Record<string, unknown>).sidebar_quote as string,
    who: e.attribution || e.blockquote_source,
  }));
---

<Layout title="How Is Incorruptible Going?">
  <Header />
  <StatsBar totalEntries={entries.length} totalEndorsements={totalEndorsements} />
  <Highlights entries={entries} />

  <nav class="timeline-nav" id="timeline-nav">
    <div class="timeline-nav__inner">
      <button class="nav-btn nav-btn--active" data-filter="all">All</button>
      <button class="nav-btn" data-filter="event">Events</button>
      <button class="nav-btn" data-filter="endorsement">Endorsements</button>
      <button class="nav-btn" data-filter="review,media,social">Reviews</button>
      <button class="nav-btn" data-filter="podcast">Podcasts</button>
      <span class="nav-count" id="nav-count"></span>
      <div class="nav-sep"></div>
      <button class="nav-btn nav-btn--jump" id="jump-today" title="Jump to today">Today</button>
      <div class="nav-sep"></div>
      <button class="nav-btn nav-btn--jump" id="jump-prev" title="Previous entry">&uarr;</button>
      <button class="nav-btn nav-btn--jump" id="jump-next" title="Next entry">&darr;</button>
    </div>
  </nav>

  <div class="layout-with-sidebar">
    <main class="timeline">
      <div class="timeline__inner">
        {/* Future / upcoming entries */}
        {futureEntries.length > 0 && (
          <div class="timeline-section">
            <div class="timeline-section__label timeline-section__label--upcoming">Upcoming</div>
            {futureEntries.map((entry, i) => (
              <TimelineEntry entry={entry} index={i} />
            ))}
          </div>
        )}

        {/* TODAY marker */}
        <div class="today-marker" id="today-marker">
          <div class="today-marker__line"></div>
          <div class="today-marker__label">Today</div>
          <div class="today-marker__line"></div>
        </div>

        {/* Past entries */}
        {pastEntries.length > 0 && (
          <div class="timeline-section">
            {pastEntries.map((entry, i) => (
              <TimelineEntry entry={entry} index={futureEntries.length + i} />
            ))}
          </div>
        )}
      </div>
    </main>

    <aside class="sidebar">
      <div class="sidebar__sticky">
        {/* ── NEWSLETTER SIGNUP ── */}
        <div class="sidebar__section sidebar__newsletter" data-collapsed>
          <div class="sidebar__newsletter-cta">
            <div class="sidebar__newsletter-info">
              <strong class="sidebar__newsletter-heading">Stay in the loop</strong>
              <span class="sidebar__newsletter-blurb">Updates on Incorruptible</span>
            </div>
            <button class="sidebar__newsletter-btn" id="newsletter-toggle" aria-label="Open subscribe form">
              <span class="sidebar__newsletter-btn-label">Subscribe</span>
              <span class="sidebar__newsletter-btn-arrow">&rarr;</span>
            </button>
          </div>
          <iframe src="https://subscribe-forms.beehiiv.com/719e9cd0-f647-4f16-afcf-a48422c5379e" class="sidebar__newsletter-embed" frameborder="0" scrolling="no" title="Subscribe to the Incorruptible newsletter" loading="lazy"></iframe>
        </div>

        {/* ── WHAT'S NEW ── */}
        {featuredEntries.length > 0 && (
          <div class="sidebar__section">
            <h3 class="sidebar__heading sidebar__heading--red">What's New</h3>
            <ul class="sidebar__list">
              {featuredEntries.map(entry => {
                const dateObj = new Date(entry.date + 'T00:00:00Z');
                const dateStr = dateObj.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
                return (
                  <li class="sidebar__item">
                    <a href={`#${entry.id}`} class="sidebar__link">
                      <span class="sidebar__date">{dateStr}</span>
                      <span class="sidebar__link-text">{entry.title}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )}

        {/* ── HIGHLIGHTS ── */}
        {sidebarQuotes.length > 0 && (
          <div class="sidebar__section">
            <h3 class="sidebar__heading sidebar__heading--blue">Highlights</h3>
            {sidebarQuotes.map(q => (
              <a href={`#${q.id}`} class="sidebar__quote-card">
                <blockquote class="sidebar__quote">&ldquo;{q.quote}&rdquo;</blockquote>
                <cite class="sidebar__cite">{q.who}</cite>
              </a>
            ))}
          </div>
        )}

        {/* ── UPCOMING EVENTS (in-person) ── */}
        {bookTourStops.length > 0 && (
          <div class="sidebar__section">
            <h3 class="sidebar__heading sidebar__heading--navy">Upcoming Events</h3>
            <ul class="sidebar__list">
              {bookTourStops.map(entry => {
                const dateObj = new Date(entry.date + 'T00:00:00Z');
                const dateStr = dateObj.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
                return (
                  <li class="sidebar__item">
                    <a href={`#${entry.id}`} class="sidebar__link sidebar__link--event">
                      <span class="sidebar__link-text">{entry.title}</span>
                      <span class="sidebar__event-meta">{entry.city} &middot; {dateStr}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )}

        {/* ── UPCOMING VIRTUAL ── */}
        {virtualEvents.length > 0 && (
          <div class="sidebar__section">
            <h3 class="sidebar__heading sidebar__heading--blue">Upcoming Virtual</h3>
            <ul class="sidebar__list">
              {virtualEvents.map(entry => {
                const dateObj = new Date(entry.date + 'T00:00:00Z');
                const dateStr = dateObj.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
                return (
                  <li class="sidebar__item">
                    <a href={`#${entry.id}`} class="sidebar__link">
                      <span class="sidebar__date">{dateStr}</span>
                      <span class="sidebar__link-text">{entry.title}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )}
      </div>
    </aside>
  </div>

  <footer class="footer">
    <p>Tracking the momentum of <a href="https://incorruptible.co" target="_blank" rel="noopener">Incorruptible</a> by Eric Ries</p>
  </footer>
</Layout>

<style>
  /* ── STICKY NAV ── */
  .timeline-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-white);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 2px 8px rgba(26, 30, 58, 0.06);
  }

  .timeline-nav__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.6rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .nav-btn {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    border: 1.5px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.15s ease;
  }

  .nav-btn:hover {
    border-color: var(--color-navy);
    color: var(--color-navy);
  }

  .nav-btn--active {
    background: var(--color-navy);
    border-color: var(--color-navy);
    color: var(--color-white);
  }

  .nav-btn--jump {
    border-color: var(--color-blue);
    color: var(--color-blue);
  }

  .nav-btn--jump:hover {
    background: var(--color-blue);
    color: var(--color-white);
  }

  .nav-count {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-text-muted);
    white-space: nowrap;
    padding: 0 0.25rem;
  }

  .nav-sep {
    width: 1px;
    height: 20px;
    background: var(--color-border);
    margin: 0 0.25rem;
    flex-shrink: 0;
  }

  /* ── TODAY MARKER ── */
  .today-marker {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 2rem 0;
    padding-left: var(--date-col-width);
    margin-left: calc(var(--date-col-width) > 0px ? 20px : 0px);
  }

  .today-marker__line {
    flex: 1;
    height: 2px;
    background: linear-gradient(90deg, var(--color-red), rgba(232, 64, 64, 0.2));
  }

  .today-marker__line:first-child {
    background: linear-gradient(90deg, rgba(232, 64, 64, 0.2), var(--color-red));
  }

  .today-marker__label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-red);
    padding: 0.25rem 0.75rem;
    border: 1.5px solid var(--color-red);
    border-radius: 999px;
    white-space: nowrap;
  }

  /* ── SECTION LABELS ── */
  .timeline-section__label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 0 0 0.75rem;
    margin-left: calc(var(--date-col-width) + 20px + var(--rail-width) + 20px);
  }

  .timeline-section__label--upcoming {
    color: var(--color-blue);
  }

  /* ── FUTURE ENTRIES: subtle opacity ── */
  .timeline-section:first-child .timeline-row {
    opacity: 0.7;
  }

  .timeline-section:first-child .timeline-row:hover {
    opacity: 1;
  }

  /* ── LAYOUT WITH SIDEBAR ── */
  .layout-with-sidebar {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    gap: 2rem;
    padding: 0 1.25rem;
  }

  /* ── TIMELINE ── */
  .timeline {
    max-width: var(--max-width);
    flex: 1;
    min-width: 0;
    padding: 2rem 0;
  }

  .timeline__inner {
    position: relative;
  }

  /* ── SIDEBAR ── */
  .sidebar {
    width: 250px;
    flex-shrink: 0;
    padding-top: 2rem;
  }

  .sidebar__sticky {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar__section {
    /* each section */
  }

  .sidebar__heading {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    padding-bottom: 0.4rem;
  }

  .sidebar__heading--red {
    color: var(--color-red);
    border-bottom: 2px solid var(--color-red);
  }

  .sidebar__heading--blue {
    color: var(--color-blue);
    border-bottom: 2px solid var(--color-blue);
  }

  .sidebar__heading--navy {
    color: var(--color-navy);
    border-bottom: 2px solid rgba(26, 30, 58, 0.2);
  }

  .sidebar__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar__item {
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar__link {
    display: block;
    padding: 0.5rem 0;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .sidebar__link:hover {
    background: rgba(108, 184, 214, 0.06);
  }

  .sidebar__date {
    display: block;
    font-family: var(--font-body);
    font-size: 0.58rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
    margin-bottom: 1px;
  }

  .sidebar__link-text {
    display: block;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-navy);
    line-height: 1.3;
  }

  .sidebar__link:hover .sidebar__link-text {
    color: var(--color-blue);
  }

  /* ── SIDEBAR QUOTE CARDS ── */
  .sidebar__quote-card {
    display: block;
    text-decoration: none;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.15s ease;
  }

  .sidebar__quote-card:hover {
    background: rgba(108, 184, 214, 0.06);
  }

  .sidebar__quote {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    font-style: normal;
    color: var(--color-text);
    line-height: 1.4;
    margin: 0;
  }

  .sidebar__cite {
    display: block;
    font-family: var(--font-body);
    font-size: 0.58rem;
    font-weight: 600;
    font-style: normal;
    color: var(--color-text-muted);
    margin-top: 0.3rem;
  }

  .sidebar__cite::before {
    content: '— ';
  }

  /* ── SIDEBAR EVENT ── */
  .sidebar__link--event .sidebar__link-text {
    font-size: 0.82rem;
    font-weight: 600;
  }

  .sidebar__event-meta {
    display: block;
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 500;
    color: var(--color-text-muted);
    margin-top: 1px;
  }

  /* Hidden by filter */
  .timeline-row.hidden {
    display: none;
  }

  /* ── SIDEBAR NEWSLETTER ── */
  .sidebar__newsletter-cta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 0.75rem;
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-navy-deep) 100%);
    border-radius: 8px;
  }

  .sidebar__newsletter-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .sidebar__newsletter-heading {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-white);
    letter-spacing: 0.01em;
  }

  .sidebar__newsletter-blurb {
    font-family: var(--font-body);
    font-size: 0.62rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.3;
  }

  .sidebar__newsletter-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: var(--color-blue);
    color: var(--color-navy);
    border: none;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .sidebar__newsletter-btn:hover {
    background: var(--color-white);
    transform: translateX(1px);
  }

  .sidebar__newsletter-btn-arrow {
    transition: transform 0.2s ease;
  }

  .sidebar__newsletter:not([data-collapsed]) .sidebar__newsletter-btn-arrow {
    transform: rotate(90deg);
  }

  .sidebar__newsletter-embed {
    width: 100%;
    border: none;
    display: block;
    border-radius: 6px;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.25s ease, margin-top 0.2s ease;
  }

  .sidebar__newsletter:not([data-collapsed]) .sidebar__newsletter-embed {
    max-height: 380px;
    opacity: 1;
    margin-top: 0.5rem;
    min-height: 280px;
  }

  .footer {
    text-align: center;
    padding: 2rem 1rem 3rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
  }

  .footer a {
    color: var(--color-blue);
    font-weight: 600;
  }

  @media (max-width: 1024px) {
    .sidebar {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .today-marker {
      padding-left: 0;
      margin-left: 0;
    }

    .timeline-section__label {
      margin-left: 0;
    }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.nav-btn[data-filter]');
  const rows = document.querySelectorAll('.timeline-row');
  const countEl = document.getElementById('nav-count');
  let currentIndex = -1;

  const getVisible = () => Array.from(rows).filter(r => !r.classList.contains('hidden'));

  function updateCount() {
    const visible = getVisible();
    const filter = document.querySelector('.nav-btn--active')?.getAttribute('data-filter');
    if (filter && filter !== 'all' && countEl) {
      countEl.textContent = `${currentIndex + 1} / ${visible.length}`;
    } else if (countEl) {
      countEl.textContent = '';
    }
  }

  function jumpTo(index: number) {
    const visible = getVisible();
    if (visible.length === 0) return;
    currentIndex = Math.max(0, Math.min(visible.length - 1, index));
    visible[currentIndex]?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    updateCount();
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('nav-btn--active'));
      btn.classList.add('nav-btn--active');

      const filter = btn.getAttribute('data-filter')!;
      const types = filter.split(',');

      rows.forEach(row => {
        const type = row.getAttribute('data-type') || '';
        if (filter === 'all' || types.includes(type)) {
          row.classList.remove('hidden');
        } else {
          row.classList.add('hidden');
        }
      });

      // Jump to first visible entry when filtering (not for "all")
      if (filter !== 'all') {
        currentIndex = -1;
        jumpTo(0);
      } else {
        currentIndex = -1;
        updateCount();
      }
    });
  });

  // Jump to today
  document.getElementById('jump-today')?.addEventListener('click', () => {
    document.getElementById('today-marker')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    currentIndex = -1;
    updateCount();
  });

  // Prev/next cycle through visible entries
  document.getElementById('jump-prev')?.addEventListener('click', () => {
    const visible = getVisible();
    if (visible.length === 0) return;
    if (currentIndex <= 0) {
      currentIndex = visible.length - 1; // wrap to end
    } else {
      currentIndex--;
    }
    jumpTo(currentIndex);
  });

  document.getElementById('jump-next')?.addEventListener('click', () => {
    const visible = getVisible();
    if (visible.length === 0) return;
    if (currentIndex >= visible.length - 1) {
      currentIndex = 0; // wrap to start
    } else {
      currentIndex++;
    }
    jumpTo(currentIndex);
  });

  // Newsletter toggle
  document.getElementById('newsletter-toggle')?.addEventListener('click', () => {
    const wrap = document.querySelector('.sidebar__newsletter');
    if (!wrap) return;
    const collapsed = wrap.hasAttribute('data-collapsed');
    if (collapsed) {
      wrap.removeAttribute('data-collapsed');
    } else {
      wrap.setAttribute('data-collapsed', '');
    }
  });
</script>
